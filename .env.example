PORT=3000
APP_BASE_URL=http://localhost:3000
SESSION_SECRET=replace-with-at-least-32-random-characters

# Production: https://searchcarriers.com
# Local SearchCarriers development: http://oauth2-third-party-integr.test
SC_BASE_URL=http://oauth2-third-party-integr.test
SC_CLIENT_ID=
SC_CLIENT_SECRET=

# Request only capabilities the example app actually uses.
SC_SCOPES=search company:read risk:read vetting:read watches:read

# Show consent again for a clear reference-app walkthrough. Use "login consent"
# locally when you also need to force account selection and reauthentication.
SC_OAUTH_PROMPT=consent
